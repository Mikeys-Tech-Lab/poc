---
import { Card, CardGrid } from '@astrojs/starlight/components';
import { getLocaleBase } from '../lib/locale';
import { getLocalizedRoutePath } from '../lib/route-map.js';
import { GITHUB } from '../consts';

const localeBase = getLocaleBase(Astro.url?.pathname ?? '/');
const pathname = Astro.url?.pathname ?? '/';
const isHome = pathname === `${localeBase}/`;
const licenseHref = getLocalizedRoutePath('license-cc-by-4-0');
---

<aside class="license-notice">
  <p>
    <strong>Author:</strong> Mikey Sebastian Drozd <sup>he/him · they/them</sup>
  </p>
  <p>
    <strong>Website:</strong>
    <a href="https://practiceofclarity.eu">practiceofclarity.eu</a>
  </p>
  <p class="legal">
    © 2026 Mikey Sebastian Drozd.
    The writing on this site is licensed under <a href={licenseHref}>CC BY 4.0</a>.
  </p>
  <p class="provenance">
    This site is built in the open. The writing is the primary reading surface. <a href={GITHUB}>The repository</a> is the inspectable node behind it.
  </p>
  {
    isHome && (
      <div class="attribution">
        <p class="attribution-lede">
          <strong>Development transparency:</strong> this publication surface is built using open tools and visible practices. The infrastructure is intentionally visible.
        </p>

        <div class="attribution-cards">
          <CardGrid>
            <Card title="Infrastructure" icon="document">
              <ul>
                <li>
                  <a href="https://www.infomaniak.com/">Infomaniak</a>: hosting
                </li>
                <li>
                  <a href="https://www.cloudflare.com/">Cloudflare</a>: edge/CDN
                </li>
              </ul>
            </Card>

            <Card title="Site framework" icon="open-book">
              <ul>
                <li><a href="https://astro.build/">Astro</a></li>
                <li><a href="https://starlight.astro.build/">Starlight</a></li>
                <li><a href="https://starlight.catppuccin.com/">@catppuccin/starlight</a></li>
              </ul>
            </Card>

            <Card title="Development" icon="pencil">
              <ul>
                <li><a href="https://cursor.com/home">Cursor</a>: AI code editor</li>
                <li><a href="https://nodejs.org/">Node.js</a></li>
                <li><a href="https://pnpm.io/">pnpm</a></li>
                <li><a href="https://sharp.pixelplumbing.com/">sharp</a></li>
              </ul>
            </Card>

            <Card title="Quality and automation" icon="approve-check">
              <ul>
                <li><a href="https://biomejs.dev/">Biome</a></li>
                <li><a href="https://vitest.dev/">Vitest</a> (and <a href="https://github.com/capricorn86/happy-dom">happy-dom</a>)</li>
                <li><a href="https://playwright.dev/">Playwright</a></li>
                <li><a href="https://github.com/features/actions">GitHub Actions</a></li>
                <li><a href="https://github.com/github/codeql-action">CodeQL</a></li>
              </ul>
              <p class="also-used">
                Honorable Mentions: <a href="https://docs.renovatebot.com/">Renovate</a>,{' '}
                <a href="https://docs.github.com/en/code-security/dependabot/dependabot-alerts/about-dependabot-alerts">Dependabot alerts</a>,{' '}
                <a href="https://github.com/googleapis/release-please-action">Release Please</a>,{' '}
                <a href="https://github.com/gitleaks/gitleaks">gitleaks</a>,{' '}
                <a href="https://github.com/ossf/scorecard-action">OSSF Scorecard</a>,{' '}
                <a href="https://github.com/projectdiscovery/nuclei">Nuclei</a>,{' '}
                <a href="https://github.com/gensecaihq/Shai-Hulud-2.0-Detector">Shai-Hulud</a>.
              </p>
            </Card>
          </CardGrid>
        </div>
      </div>
    )
  }
</aside>

<style>
  .license-notice {
    margin-block-start: 3rem;
    padding: 1rem 1.25rem;
    border-block-start: 1px solid var(--poc-border, var(--sl-color-gray-5));
    font-size: var(--sl-text-xs);
    color: var(--sl-color-gray-3);
    line-height: 1.6;
  }

  .license-notice p {
    margin: 0.25em 0;
  }

  .pronouns {
    opacity: 0.7;
  }

  .legal {
    margin-block-start: 0.5em;
  }

  .provenance {
    opacity: 0.6;
    font-style: italic;
  }

  .license-notice a {
    color: var(--sl-color-text-accent);
    text-decoration: none;
  }

  .license-notice a:hover {
    text-decoration: underline;
  }

  .attribution {
    margin-block-start: 0.75em;
    --poc-attribution-gap: 1rem;
    padding-block-start: var(--poc-attribution-gap);
    border-block-start: 1px solid var(--poc-border-subtle, var(--sl-color-gray-6));
    display: flex;
    flex-direction: column;
    gap: var(--poc-attribution-gap);
  }

  .attribution-lede {
    opacity: 0.9;
    margin: 0;
    font-size: clamp(var(--sl-text-sm), calc(0.0625rem + 1.6vw), var(--sl-text-lg));
    line-height: var(--sl-line-height);
    color: var(--sl-color-gray-2);
  }

  .attribution-cards {
    margin: 0;
  }

  .attribution-cards :global(.card-grid) {
    gap: 1.25rem;
  }

  .attribution-cards :global(.card) {
    background-color: var(--poc-surface-mid, rgb(var(--poc-base) / 0.35));
    border-color: var(--poc-border, var(--sl-color-gray-5));
  }

  .attribution-cards :global(.card .title) {
    color: var(--sl-color-white);
  }

  :root[data-theme="light"] .attribution-cards :global(.card .title) {
    color: var(--sl-color-gray-1);
  }

  .attribution-cards :global(.card .body) {
    color: var(--sl-color-gray-2);
    font-size: var(--sl-text-sm);
    line-height: 1.7;
  }

  .attribution-cards :global(.card .body ul) {
    margin: 0.25em 0 0;
    padding-inline-start: 1.1em;
  }

  .attribution-cards :global(.card .body li) {
    margin: 0.35em 0;
  }

  .attribution-cards :global(.card .body .also-used) {
    margin: 0.75em 0 0;
    opacity: 0.8;
  }

  @media (min-width: 50rem) {
    .attribution {
      --poc-attribution-gap: 1.5rem;
    }
  }
</style>
