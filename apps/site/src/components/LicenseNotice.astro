---
import { REPO } from "../consts";

interface Props {
  sourceFilePath?: string;
}

const { sourceFilePath } = Astro.props;
const sha: string = typeof __COMMIT_SHA__ !== "undefined" ? __COMMIT_SHA__ : "unknown";
const shortSha = sha !== "unknown" ? sha.slice(0, 7) : sha;
const sourceUrl =
  sourceFilePath && sha !== "unknown"
    ? `${REPO}/blob/${sha}/${sourceFilePath}`
    : REPO;
---

<aside class="license-notice">
  <p>
    <strong>Author:</strong> Mikey Sebastian Drozd
    <span class="pronouns">(he/him · they/them)</span>
  </p>
  <p>
    <strong>Website:</strong>
    <a href="https://practiceofclarity.eu">practiceofclarity.eu</a>
    {sourceFilePath && (
      <>
        &nbsp;·&nbsp;
        <a href={sourceUrl} class="source-link" title={`Source at ${shortSha}`}>{shortSha}</a>
      </>
    )}
  </p>
  <p class="legal">
    © 2026 Mikey Sebastian Drozd.
    Licensed under <a href={`${REPO}/blob/main/LICENSE-CC-BY-4.0`}>CC BY 4.0</a>.
    Repository code and tooling: <a href={`${REPO}/blob/main/LICENSE`}>MIT</a>.
  </p>
</aside>

<style>
  .license-notice {
    margin-block-start: 3rem;
    padding: 1rem 1.25rem;
    border-block-start: 1px solid var(--poc-border, var(--sl-color-gray-5));
    font-size: var(--sl-text-xs);
    color: var(--sl-color-gray-3);
    line-height: 1.6;
  }

  .license-notice p {
    margin: 0.25em 0;
  }

  .pronouns {
    opacity: 0.7;
  }

  .legal {
    margin-block-start: 0.5em;
  }

  .license-notice a {
    color: var(--sl-color-text-accent);
    text-decoration: none;
  }

  .license-notice a:hover {
    text-decoration: underline;
  }

  .source-link {
    font-family: var(--sl-font-mono, monospace);
    font-size: 0.9em;
    opacity: 0.7;
  }
</style>
