---
import { getRegisterLabels } from '../lib/i18n';
import { getLocaleFromPath } from '../lib/locale';
import { READING_REGISTERS } from '../lib/register-registry.js';
import { getRegisterAvailabilityForPath } from '../lib/route-map.js';

const locale = getLocaleFromPath(Astro.url?.pathname ?? '/');
const t = getRegisterLabels(locale);
const registerAvailability = getRegisterAvailabilityForPath(Astro.url?.pathname ?? '/');

type ReadingRegister = 'everyday' | 'orientation' | 'practitioner';
const readingRegisters = READING_REGISTERS as readonly ReadingRegister[];
const absentRegisters = registerAvailability.absent as Partial<Record<ReadingRegister, string>>;
const registerLabel = {
  everyday: t.everyday,
  orientation: t.orientation,
  practitioner: t.practitioner,
};
const registerHelper = {
  everyday: t.everydayHelper,
  orientation: t.orientationHelper,
  practitioner: t.practitionerHelper,
};
---

<poc-register-fab class="register-fab" data-register-fab>
  <button
    type="button"
    class="register-fab-trigger"
    data-register-fab-trigger
    aria-haspopup="dialog"
    aria-expanded="false"
    aria-controls="poc-register-fab-panel"
  >
    <svg
      aria-hidden="true"
      class="register-fab-icon"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2.4"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <circle cx="9" cy="12" r="7" opacity="0.64"></circle>
      <circle cx="15" cy="12" r="7" opacity="0.64"></circle>
    </svg>
    <span class="register-fab-current" data-register-fab-current>{t.practitioner}</span>
  </button>

  <section
    id="poc-register-fab-panel"
    class="register-fab-panel"
    data-register-fab-panel
    role="dialog"
    aria-labelledby="poc-register-fab-title"
    hidden
  >
    <div class="register-fab-panel-head">
      <div>
        <p class="register-fab-kicker">{t.selectorLabel}</p>
        <h2 id="poc-register-fab-title">{t.selectorLabel}</h2>
        <p>{t.controlDescription}</p>
      </div>
      <button type="button" class="register-fab-close" data-register-fab-close>
        <span class="sr-only">{t.closeControl}</span>
        <svg aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round">
          <path d="M6 6l12 12M18 6L6 18"></path>
        </svg>
      </button>
    </div>

    <fieldset class="register-fab-options">
      <legend class="sr-only">{t.selectorLabel}</legend>
      {
        readingRegisters.map((register) => {
          const isAvailable = registerAvailability.available.includes(register);
          const unavailableMessage = absentRegisters[register];
          const label = registerLabel[register];
          return (
            <label
              class:list={{
                'register-fab-option': true,
                'is-unavailable': !isAvailable,
              }}
              aria-disabled={!isAvailable ? 'true' : undefined}
            >
              <input
                type="radio"
                name="poc-register-fab-choice"
                value={register}
                disabled={!isAvailable}
                data-register-label={label}
                data-register-helper={registerHelper[register]}
                data-register-unavailable-message={unavailableMessage}
              />
              <span class="register-fab-option-copy">
                <span class="register-fab-option-title">
                  {isAvailable ? label : `${label} (${t.unavailableSuffix})`}
                </span>
                <span class="register-fab-option-helper">
                  {isAvailable ? registerHelper[register] : unavailableMessage}
                </span>
              </span>
            </label>
          );
        })
      }
    </fieldset>

    <p class="register-fab-fallback" data-register-fab-fallback role="status" hidden></p>

    <label class="register-fab-compact">
      <input type="checkbox" data-register-fab-compact />
      <span>{t.compactToggle}</span>
    </label>
  </section>
</poc-register-fab>

<script>
  import { getRegister, setRegister, type Register } from '../lib/register';
  import { rebuildToc } from '../lib/toc';

  const COMPACT_STORAGE_KEY = 'poc-register-control-compact';

  const currentLabel = (register: string) => {
    const input = document.querySelector<HTMLInputElement>(
      `poc-register-fab input[name="poc-register-fab-choice"][value="${CSS.escape(register)}"]`,
    );
    return input?.dataset.registerLabel ?? register;
  };

  class PocRegisterFab extends HTMLElement {
    #trigger: HTMLButtonElement | null = null;
    #panel: HTMLElement | null = null;

    connectedCallback() {
      this.#trigger = this.querySelector('[data-register-fab-trigger]');
      this.#panel = this.querySelector('[data-register-fab-panel]');
      const close = this.querySelector('[data-register-fab-close]');
      const compact = this.querySelector<HTMLInputElement>('[data-register-fab-compact]');

      this.#trigger?.addEventListener('click', () => this.togglePanel());
      close?.addEventListener('click', () => this.closePanel());
      compact?.addEventListener('change', () => {
        this.setCompact(Boolean(compact.checked));
      });

      this.querySelectorAll<HTMLInputElement>('input[name="poc-register-fab-choice"]').forEach(
        (input) => {
          input.addEventListener('change', () => {
            if (input.checked && !input.disabled) {
              setRegister(input.value as Register);
              this.closePanel({ restoreFocus: false });
            }
          });
        },
      );

      document.addEventListener('pointerdown', (event) => {
        if (!this.#panel || this.#panel.hidden || this.contains(event.target as Node)) return;
        this.closePanel({ restoreFocus: false });
      });
      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape' && this.#panel && !this.#panel.hidden) {
          this.closePanel();
        }
      });
      window.addEventListener('poc:register-change', () => {
        this.sync();
        rebuildToc();
      });

      const storedCompact =
        typeof localStorage !== 'undefined' && localStorage.getItem(COMPACT_STORAGE_KEY);
      this.setCompact(storedCompact === 'true', { persist: false });

      const requestedRegister = document.documentElement.dataset.registerRequested;
      setRegister((requestedRegister ?? getRegister()) as Register);
      this.sync();
    }

    togglePanel() {
      if (!this.#panel || !this.#trigger) return;
      if (this.#panel.hidden) {
        this.#panel.hidden = false;
        this.#trigger.setAttribute('aria-expanded', 'true');
        this.querySelector<HTMLInputElement>('input[name="poc-register-fab-choice"]:checked')?.focus();
        return;
      }

      this.closePanel();
    }

    closePanel({ restoreFocus = true } = {}) {
      if (!this.#panel || !this.#trigger) return;
      this.#panel.hidden = true;
      this.#trigger.setAttribute('aria-expanded', 'false');
      if (restoreFocus) {
        this.#trigger.focus();
      }
    }

    setCompact(value: boolean, { persist = true } = {}) {
      this.dataset.compact = value ? 'true' : 'false';
      const compact = this.querySelector<HTMLInputElement>('[data-register-fab-compact]');
      if (compact) {
        compact.checked = value;
      }
      if (persist && typeof localStorage !== 'undefined') {
        localStorage.setItem(COMPACT_STORAGE_KEY, value ? 'true' : 'false');
      }
    }

    sync() {
      const root = document.documentElement;
      const register = getRegister();
      this.querySelectorAll<HTMLInputElement>('input[name="poc-register-fab-choice"]').forEach(
        (input) => {
          input.checked = input.value === register;
        },
      );

      const current = this.querySelector('[data-register-fab-current]');
      if (current instanceof HTMLElement) {
        current.textContent = currentLabel(register);
      }
      if (this.#trigger) {
        this.#trigger.setAttribute('aria-label', `${currentLabel(register)} reading register`);
      }

      const fallback = this.querySelector('[data-register-fab-fallback]');
      if (fallback instanceof HTMLElement) {
        const message = root.dataset.registerFallbackMessage;
        fallback.hidden = !message;
        fallback.textContent = message ?? '';
      }
    }
  }

  if (!customElements.get('poc-register-fab')) {
    customElements.define('poc-register-fab', PocRegisterFab);
  }
</script>

<style>
  .register-fab {
    position: fixed;
    z-index: 110;
    top: calc(var(--sl-nav-height) + 0.9rem);
    right: max(1rem, env(safe-area-inset-right));
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.75rem;
    width: max-content;
    height: max-content;
    pointer-events: none;
  }

  .register-fab-trigger,
  .register-fab-panel {
    pointer-events: auto;
  }

  .register-fab-trigger {
    order: 1;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.45rem;
    min-width: 3.75rem;
    min-height: 3.75rem;
    border: 1.5px solid color-mix(in srgb, var(--poc-register-accent) 52%, var(--poc-box-border));
    border-radius: 999px;
    background:
      radial-gradient(circle at 30% 24%, rgb(255 255 255 / 0.2), transparent 38%),
      color-mix(in srgb, var(--poc-surface-panel) 84%, var(--poc-register-accent) 16%);
    color: var(--poc-text-strong);
    box-shadow:
      0 0 0 1px rgb(255 255 255 / 0.04) inset,
      0 12px 32px rgb(0 0 0 / 0.28),
      0 0 26px color-mix(in srgb, var(--poc-register-accent) 24%, transparent);
    cursor: pointer;
    font: 700 0.78rem/1 var(--sl-font);
    letter-spacing: 0.02em;
    padding: 0.8rem;
    transition:
      transform 160ms ease,
      border-color 160ms ease,
      box-shadow 160ms ease,
      opacity 160ms ease;
    backdrop-filter: blur(var(--poc-blur-md));
  }

  .register-fab-trigger:hover {
    transform: translateY(-2px);
    border-color: color-mix(in srgb, var(--poc-register-accent) 76%, white 24%);
    box-shadow:
      0 0 0 1px rgb(255 255 255 / 0.06) inset,
      0 16px 42px rgb(0 0 0 / 0.32),
      0 0 34px color-mix(in srgb, var(--poc-register-accent) 32%, transparent);
  }

  .register-fab-trigger:focus-visible,
  .register-fab-close:focus-visible,
  .register-fab-option:has(input:focus-visible),
  .register-fab-compact:has(input:focus-visible) {
    outline: 2px solid var(--sl-color-text-accent);
    outline-offset: 3px;
  }

  .register-fab-icon {
    width: 1.45rem;
    height: 1.45rem;
    flex: 0 0 auto;
  }

  .register-fab-current {
    max-width: 7rem;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .register-fab[data-compact='true'] .register-fab-trigger {
    min-width: 2.6rem;
    min-height: 2.6rem;
    opacity: 0.68;
    padding: 0.58rem;
  }

  .register-fab[data-compact='true'] .register-fab-current {
    position: absolute;
    inline-size: 1px;
    block-size: 1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
    white-space: nowrap;
  }

  .register-fab-panel {
    order: 2;
    width: min(22rem, calc(100vw - 2rem));
    max-height: calc(100dvh - var(--sl-nav-height) - 6rem);
    overflow-y: auto;
    border: var(--poc-box-border-width) solid
      color-mix(in srgb, var(--poc-register-accent) 34%, var(--poc-box-border));
    border-radius: 1.35rem;
    background:
      linear-gradient(
        145deg,
        color-mix(in srgb, var(--poc-surface-panel) 88%, var(--poc-register-accent) 12%),
        var(--poc-surface-panel)
      );
    color: var(--poc-text);
    box-shadow: var(--poc-shadow-medium);
    padding: 1rem;
    backdrop-filter: blur(var(--poc-blur-lg));
  }

  .register-fab-panel[hidden] {
    display: none;
  }

  .register-fab-panel-head {
    display: flex;
    gap: 0.75rem;
    justify-content: space-between;
    align-items: flex-start;
    margin-block-end: 0.85rem;
  }

  .register-fab-panel-head h2,
  .register-fab-panel-head p {
    margin: 0;
  }

  .register-fab-panel-head h2 {
    color: var(--poc-text-strong);
    font-size: 1rem;
    line-height: 1.2;
  }

  .register-fab-panel-head p:not(.register-fab-kicker) {
    margin-block-start: 0.2rem;
    color: var(--poc-text-soft);
    font-size: 0.84rem;
  }

  .register-fab-kicker {
    color: var(--poc-register-accent);
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .register-fab-close {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.1rem;
    height: 2.1rem;
    border: 1px solid var(--poc-box-control-border);
    border-radius: 999px;
    background: var(--poc-box-control-surface);
    color: var(--poc-text-muted);
    cursor: pointer;
  }

  .register-fab-close svg {
    width: 1rem;
    height: 1rem;
  }

  .register-fab-options {
    display: grid;
    gap: 0.5rem;
    border: 0;
    margin: 0;
    padding: 0;
  }

  .register-fab-option {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.65rem;
    align-items: start;
    border: 1px solid var(--poc-box-row-border);
    border-radius: 0.95rem;
    background: var(--poc-box-row-surface);
    cursor: pointer;
    padding: 0.72rem 0.78rem;
    transition:
      background-color 140ms ease,
      border-color 140ms ease,
      transform 140ms ease;
  }

  .register-fab-option:hover {
    border-color: var(--poc-box-row-hover-border);
    transform: translateY(-1px);
  }

  .register-fab-option:has(input:checked) {
    border-color: var(--poc-box-selected-border);
    background: var(--poc-box-selected-surface);
    box-shadow: 0 0 0 4px var(--poc-box-selected-ring);
  }

  .register-fab-option.is-unavailable {
    cursor: not-allowed;
    opacity: 0.66;
  }

  .register-fab-option input {
    margin-block-start: 0.2rem;
    accent-color: var(--poc-register-accent);
  }

  .register-fab-option-title {
    display: block;
    color: var(--poc-text-strong);
    font-size: 0.9rem;
    font-weight: 700;
    line-height: 1.2;
  }

  .register-fab-option-helper {
    display: block;
    margin-block-start: 0.16rem;
    color: var(--poc-text-soft);
    font-size: 0.78rem;
    line-height: 1.35;
  }

  .register-fab-fallback {
    border-left: 3px solid var(--poc-register-accent);
    color: var(--poc-text-muted);
    font-size: 0.8rem;
    margin: 0.8rem 0 0;
    padding-inline-start: 0.65rem;
  }

  .register-fab-compact {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    color: var(--poc-text-soft);
    cursor: pointer;
    font-size: 0.8rem;
    margin-block-start: 0.85rem;
  }

  .register-fab-compact input {
    accent-color: var(--poc-register-accent);
  }

  @media (max-width: 40rem) {
    .register-fab {
      top: calc(var(--sl-nav-height) + 0.75rem);
      right: max(0.75rem, env(safe-area-inset-right));
    }

    .register-fab-panel {
      width: min(21rem, calc(100vw - 1.5rem));
      border-radius: 1.15rem;
      padding: 0.85rem;
    }
  }
</style>
