---
import { getEntry, render } from 'astro:content';

interface Props {
	register?: string;
	registers?: Partial<Record<'everyday' | 'orientation', string>>;
}

const { register: registerEntry, registers = {} } = Astro.props;

const registerEntryPaths = {
	...(registerEntry ? { orientation: registerEntry } : {}),
	...registers,
};

const renderedRegisterEntries: Array<{ register: 'everyday' | 'orientation'; Content: any }> = [];

for (const register of ['everyday', 'orientation'] as const) {
	const entryPath = registerEntryPaths[register];
	if (!entryPath) continue;

	const match = await getEntry('register', entryPath)
		?? await getEntry('register', entryPath.replace(/\/index$/, ''));
	if (match) {
		const rendered = await render(match);
		renderedRegisterEntries.push({ register, Content: rendered.Content });
	}
}
---

<noscript>
	<p class="register-noscript-note">
		Showing the practitioner register. Register switching requires JavaScript.
	</p>
</noscript>

<div data-register-content="practitioner">
	<slot />
</div>

{renderedRegisterEntries.map(({ register, Content }) => (
	<div data-register-content={register}>
		<Content />
	</div>
))}

<script>
	import { rebuildToc } from '../lib/toc';

	const rebuildVisibleToc = () => window.requestAnimationFrame(() => rebuildToc());

	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', rebuildVisibleToc, { once: true });
	} else {
		rebuildVisibleToc();
	}

	window.addEventListener('poc:register-change', rebuildVisibleToc);
</script>

<style is:global>
	[data-register-content] {
		display: none;
	}

	.register-noscript-note {
		margin-block: 0 1rem;
		padding: 0.75rem 0.9rem;
		border: 1px solid var(--sl-color-gray-5);
		border-radius: 0.75rem;
		color: var(--sl-color-gray-2);
		font-size: var(--sl-text-sm);
	}

	:root:not([data-register]) [data-register-content='practitioner'] {
		display: contents;
	}

	:root[data-register='practitioner'] [data-register-content='practitioner'],
	:root[data-register='orientation'] [data-register-content='orientation'],
	:root[data-register='everyday'] [data-register-content='everyday'] {
		display: contents;
	}
</style>
