---
import { getEntry, render } from 'astro:content';

interface Props {
	register?: string;
}

const { register: registerEntry } = Astro.props;

let RegisterEntryContent: any = null;

if (registerEntry) {
	const match = await getEntry('register', registerEntry)
		?? await getEntry('register', registerEntry.replace(/\/index$/, ''));
	if (match) {
		const rendered = await render(match);
		RegisterEntryContent = rendered.Content;
	}
}
---

<div data-register-content="practitioner">
	<slot />
</div>

{
	RegisterEntryContent && (
		<div data-register-content="orientation">
			<RegisterEntryContent />
		</div>
	)
}

<style is:global>
	[data-register-content='orientation'] {
		display: none;
	}

	:root[data-register='orientation'] [data-register-content='practitioner'] {
		display: none;
	}

	:root[data-register='orientation'] [data-register-content='orientation'] {
		display: contents;
	}
</style>
