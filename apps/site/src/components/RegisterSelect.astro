---
---

<poc-register-toggle>
  <button type="button" aria-label="Register">
    <span class="sr-only">Register</span>
    <svg
      aria-hidden="true"
      class="icon label-icon"
      width="16"
      height="16"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <circle cx="9" cy="12" r="7" opacity="0.6" />
      <circle cx="15" cy="12" r="7" opacity="0.6" />
    </svg>

    <span class="text" aria-hidden="true">
      <span class="label label-practitioner">Practitioner</span>
      <span class="label label-beginner">Beginner</span>
    </span>
  </button>
</poc-register-toggle>

<script>
  type Register = 'practitioner' | 'beginner';

  const storageKey = 'poc-register';

  const parseRegister = (value: unknown): Register =>
    value === 'beginner' ? 'beginner' : 'practitioner';

  const loadRegister = (): Register =>
    parseRegister(
      typeof localStorage !== 'undefined' && localStorage.getItem(storageKey)
    );

  function applyRegister(register: Register): void {
    document.documentElement.dataset.register = register;
    if (typeof localStorage !== 'undefined') {
      localStorage.setItem(storageKey, register);
    }
    document.querySelectorAll('poc-register-toggle button').forEach((btn) => {
      if (btn instanceof HTMLButtonElement) {
        btn.setAttribute('aria-pressed', register === 'beginner' ? 'true' : 'false');
      }
    });
  }

  class PocRegisterToggle extends HTMLElement {
    constructor() {
      super();
      applyRegister(loadRegister());

      this.querySelector('button')?.addEventListener('click', () => {
        const current = parseRegister(document.documentElement.dataset.register);
        const next: Register = current === 'beginner' ? 'practitioner' : 'beginner';
        applyRegister(next);
      });
    }
  }
  customElements.define('poc-register-toggle', PocRegisterToggle);
</script>

<style>
  button {
    --sl-label-icon-size: 0.875rem;
    --sl-inline-padding: 0.5rem;
    position: relative;
    display: flex;
    align-items: center;
    gap: 0.25rem;
    color: var(--poc-register-accent);
    background: transparent;
    border: 0;
    padding-block: 0.625rem;
    padding-inline:
      calc(var(--sl-label-icon-size) + var(--sl-inline-padding) + 0.25rem)
      calc(var(--sl-inline-padding) + 0.25rem);
    margin-inline: calc(var(--sl-inline-padding) * -1);
    cursor: pointer;
    font-size: var(--sl-text-sm);
  }

  button:hover {
    opacity: 0.66;
  }

  .icon {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    pointer-events: none;
  }

  .label-icon {
    font-size: var(--sl-label-icon-size);
    inset-inline-start: 0;
    width: var(--sl-label-icon-size);
    height: var(--sl-label-icon-size);
  }

  .text {
    display: inline-flex;
    align-items: baseline;
    min-width: 8.5em;
  }

  .label-beginner {
    display: none;
  }

  :global(:root[data-register='beginner']) .label-practitioner {
    display: none;
  }

  :global(:root[data-register='beginner']) .label-beginner {
    display: inline;
  }
</style>
