---
interface Props {
  title: string;
  label?: string;
  body: string;
  copyButtonLabel: string;
  copyTargetId: string;
}

const {
  title,
  label = 'Prompt',
  body,
  copyButtonLabel,
  copyTargetId,
} = Astro.props as Props;
---

<div class="copy-prompt-card">
  <div class="copy-prompt-card-header">
    <div>
      <p class="copy-prompt-card-label">{label}</p>
      <p class="copy-prompt-card-title">{title}</p>
    </div>
    <button
      type="button"
      class="copy-prompt-card-copy"
      data-copy-target={copyTargetId}
      aria-label={copyButtonLabel}
    >
      <span data-copy-default>{copyButtonLabel}</span>
      <span data-copy-success hidden>Copied</span>
    </button>
  </div>
  <pre><code data-copy-source={copyTargetId}>{body}</code></pre>
</div>

<style>
  .copy-prompt-card {
    display: grid;
    gap: 0.75rem;
    margin: 1.25rem 0;
    padding: 1rem 1.05rem;
    border: var(--poc-box-border-width) solid var(--poc-box-activation-border);
    border-radius: 0.9rem;
    border-inline-start: 0.24rem solid var(--poc-box-activation-rail);
    background-color: var(--poc-box-activation-surface);
    box-shadow: var(--poc-box-shadow);
    box-sizing: border-box;
    min-width: 0;
    max-width: 100%;
  }

  :root:not([data-style='solid']) .copy-prompt-card {
    backdrop-filter: blur(var(--poc-blur-sm));
  }

  .copy-prompt-card-header {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    align-items: flex-start;
    justify-content: space-between;
  }

  .copy-prompt-card-header > div {
    min-width: 0;
  }

  .copy-prompt-card-label,
  .copy-prompt-card-title {
    margin: 0;
  }

  .copy-prompt-card-label {
    color: var(--poc-text-soft);
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .copy-prompt-card-title {
    margin-top: 0.3rem;
    font-size: 1rem;
    font-weight: 600;
    color: var(--poc-box-activation-title);
  }

  .copy-prompt-card-copy {
    display: inline-flex;
    align-items: center;
    gap: 0.35em;
    padding: 0.42em 0.78em;
    border: 1px solid var(--poc-box-control-border);
    border-radius: 0.6em;
    background: var(--poc-box-control-surface);
    box-shadow: var(--poc-box-control-shadow);
    color: var(--poc-text-strong, var(--sl-color-gray-2));
    font-size: var(--sl-text-xs);
    cursor: pointer;
    transition:
      color 0.15s ease,
      border-color 0.15s ease,
      background-color 0.15s ease,
      transform 0.15s ease;
    line-height: 1;
    max-width: 100%;
    white-space: normal;
    text-align: center;
    justify-content: center;
  }

  :root:not([data-style='solid']) .copy-prompt-card-copy {
    backdrop-filter: blur(var(--poc-blur-sm, 8px));
  }

  .copy-prompt-card-copy:hover {
    color: var(--sl-color-text-accent);
    border-color: var(--poc-box-control-hover-border);
    background: var(--poc-box-control-hover-surface);
    transform: translateY(-1px);
  }

  .copy-prompt-card-copy:focus-visible {
    outline: 2px solid var(--sl-color-text-accent);
    outline-offset: 2px;
  }

  .copy-prompt-card pre {
    margin: 0;
    padding: 0.95rem 1rem;
    border: 1px solid var(--poc-box-control-border);
    border-radius: 0.8rem;
    background-color: var(--poc-box-control-surface);
    box-shadow: inset 0 1px 0 rgb(255 255 255 / 0.02);
    white-space: pre-wrap;
    overflow-wrap: anywhere;
    box-sizing: border-box;
    max-width: 100%;
  }

  .copy-prompt-card code {
    display: block;
    font-size: 0.92rem;
    line-height: 1.6;
  }

  @media (max-width: 32rem) {
    .copy-prompt-card-header {
      flex-direction: column;
      align-items: stretch;
    }

    .copy-prompt-card-copy {
      width: 100%;
    }
  }
</style>
