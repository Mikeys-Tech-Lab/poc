---
import config from 'virtual:starlight/user-config';
import { logos } from 'virtual:starlight/user-images';
import { getLocaleFromPath } from '../lib/locale';
import { getRegisterLabels } from '../lib/i18n';

const { siteTitle } = Astro.locals.starlightRoute;
const locale = getLocaleFromPath(Astro.url?.pathname ?? '/');
const t = getRegisterLabels(locale);
---

<div class="site-title sl-flex" aria-label={`${siteTitle}. Current reading register indicator.`}>
  {
    config.logo && logos.dark && (
      <>
        <img
          class:list={{ 'light:sl-hidden print:hidden': !('src' in config.logo) }}
          alt={config.logo.alt}
          src={logos.dark.src}
          width={logos.dark.width}
          height={logos.dark.height}
        />
        {!('src' in config.logo) && (
          <img
            class="dark:sl-hidden print:block"
            alt={config.logo.alt}
            src={logos.light?.src}
            width={logos.light?.width}
            height={logos.light?.height}
          />
        )}
      </>
    )
  }
  <span class:list={{ 'sr-only': config.logo?.replacesTitle, 'title-copy': true }} translate="no">
    <span class="title-main">
      {siteTitle}<sup class="register-label"><svg aria-hidden="true" class="register-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="12" r="7" opacity="0.6" /><circle cx="15" cy="12" r="7" opacity="0.6" /></svg><span class="label-practitioner">{t.practitioner}</span><span class="label-orientation">{t.orientation}</span><span class="label-everyday">{t.everyday}</span></sup>
    </span>
    <span class="register-helper" aria-hidden="true">
      <span class="helper-practitioner">{t.practitionerHelper}</span>
      <span class="helper-orientation">{t.orientationHelper}</span>
      <span class="helper-everyday">{t.everydayHelper}</span>
    </span>
  </span>
</div>

<style>
  @layer starlight.core {
    .site-title {
      align-items: center;
      gap: var(--sl-nav-gap);
      font-size: var(--sl-text-h4);
      font-weight: 600;
      color: var(--sl-color-text-accent);
      text-decoration: none;
      white-space: nowrap;
      min-width: 0;
      padding: 0;
      font-family: var(--sl-font);
      line-height: normal;
    }

    span {
      overflow: visible;
    }

    img {
      height: calc(var(--sl-nav-height) - 2 * var(--sl-nav-pad-y));
      width: auto;
      max-width: 100%;
      object-fit: contain;
      object-position: 0 50%;
    }
  }

  .register-label {
    font-size: 0.65em;
    font-weight: 400;
    color: var(--poc-register-accent);
    margin-inline-start: 0.4em;
    vertical-align: super;
    letter-spacing: 0.02em;
    transition: color 0.3s ease;
    display: inline-flex;
    align-items: center;
    gap: 0.25em;
    line-height: 1;
    flex-shrink: 1;
    min-width: 0;
  }

  .register-icon {
    flex-shrink: 0;
    width: 1.5cap;
    height: 1.5cap;
    align-self: center;
  }

  .title-copy {
    display: inline-flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.15rem;
    min-width: 0;
  }

  .title-main {
    display: inline-block;
  }

  .register-helper {
    display: block;
    font-size: 0.48em;
    font-weight: 400;
    color: var(--sl-color-gray-3);
    letter-spacing: 0.01em;
    line-height: 1.25;
    white-space: normal;
    max-width: 22rem;
  }

  .label-orientation,
  .label-everyday,
  .helper-orientation,
  .helper-everyday {
    display: none;
  }

  :global(:root[data-register='orientation']) .label-practitioner,
  :global(:root[data-register='orientation']) .helper-practitioner,
  :global(:root[data-register='everyday']) .label-practitioner,
  :global(:root[data-register='everyday']) .helper-practitioner {
    display: none;
  }

  :global(:root[data-register='orientation']) .label-orientation,
  :global(:root[data-register='orientation']) .helper-orientation,
  :global(:root[data-register='everyday']) .label-everyday,
  :global(:root[data-register='everyday']) .helper-everyday {
    display: inline;
  }

  @media (max-width: 72rem) {
    .register-helper {
      font-size: 0.44em;
      max-width: min(18rem, 55vw);
    }
  }
</style>
