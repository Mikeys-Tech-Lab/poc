---
import config from 'virtual:starlight/user-config';
import { logos } from 'virtual:starlight/user-images';

const { siteTitle } = Astro.locals.starlightRoute;

const pathname = Astro.url?.pathname ?? '/';
const lang = pathname.startsWith('/de-de/')
  ? 'de-DE'
  : pathname.startsWith('/en-gb/')
    ? 'en-GB'
    : 'en-US';

const labels: Record<string, { practitioner: string; beginner: string }> = {
  'en-US': { practitioner: 'Practitioner', beginner: 'Beginner' },
  'en-GB': { practitioner: 'Practitioner', beginner: 'Beginner' },
  'de-DE': { practitioner: 'Praktiker', beginner: 'Anfänger' },
};

const t = labels[lang] ?? labels['en-US'];
---

<poc-register-toggle>
  <button type="button" class="site-title sl-flex">
    {
      config.logo && logos.dark && (
        <>
          <img
            class:list={{ 'light:sl-hidden print:hidden': !('src' in config.logo) }}
            alt={config.logo.alt}
            src={logos.dark.src}
            width={logos.dark.width}
            height={logos.dark.height}
          />
          {!('src' in config.logo) && (
            <img
              class="dark:sl-hidden print:block"
              alt={config.logo.alt}
              src={logos.light?.src}
              width={logos.light?.width}
              height={logos.light?.height}
            />
          )}
        </>
      )
    }
    <span class:list={{ 'sr-only': config.logo?.replacesTitle }} translate="no">
      {siteTitle}<sup class="register-label"><svg aria-hidden="true" class="register-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="12" r="7" opacity="0.6" /><circle cx="15" cy="12" r="7" opacity="0.6" /></svg><span class="label-practitioner">{t.practitioner}</span><span class="label-beginner">{t.beginner}</span></sup>
    </span>
  </button>
</poc-register-toggle>

<script>
  type Register = 'practitioner' | 'beginner';

  const storageKey = 'poc-register';

  const parseRegister = (value: unknown): Register =>
    value === 'beginner' ? 'beginner' : 'practitioner';

  const loadRegister = (): Register =>
    parseRegister(
      typeof localStorage !== 'undefined' && localStorage.getItem(storageKey)
    );

  function syncUrlParam(register: Register): void {
    const url = new URL(window.location.href);
    if (register === 'beginner') {
      url.searchParams.set('register', 'beginner');
    } else {
      url.searchParams.delete('register');
    }
    history.replaceState(null, '', url);
  }

  function rebuildToc(): void {
    const tocNav = document.querySelector('starlight-toc nav > ul');
    if (!tocNav) return;

    const register = document.documentElement.dataset.register || 'practitioner';
    const content = document.querySelector(`[data-register-content="${register}"]`);
    if (!content) return;

    const headings = content.querySelectorAll('h2, h3');
    if (headings.length === 0) return;

    tocNav.innerHTML = '';
    let currentH2Li: HTMLLIElement | null = null;

    headings.forEach((h) => {
      if (!h.id || !h.textContent) return;
      const li = document.createElement('li');
      const a = document.createElement('a');
      a.href = `#${h.id}`;
      a.textContent = h.textContent.trim();

      if (h.tagName === 'H3' && currentH2Li) {
        let sub = currentH2Li.querySelector(':scope > ul');
        if (!sub) {
          sub = document.createElement('ul');
          currentH2Li.appendChild(sub);
        }
        li.appendChild(a);
        sub.appendChild(li);
      } else {
        li.appendChild(a);
        tocNav.appendChild(li);
        if (h.tagName === 'H2') currentH2Li = li;
      }
    });
  }

  function applyRegister(register: Register): void {
    document.documentElement.dataset.register = register;
    if (typeof localStorage !== 'undefined') {
      localStorage.setItem(storageKey, register);
    }
    syncUrlParam(register);
    document.querySelectorAll('poc-register-toggle button').forEach((btn) => {
      if (btn instanceof HTMLButtonElement) {
        btn.setAttribute('aria-pressed', register === 'beginner' ? 'true' : 'false');
      }
    });
    rebuildToc();
  }

  class PocRegisterToggle extends HTMLElement {
    constructor() {
      super();
      applyRegister(loadRegister());

      this.querySelector('button')?.addEventListener('click', () => {
        const current = parseRegister(document.documentElement.dataset.register);
        const next: Register = current === 'beginner' ? 'practitioner' : 'beginner';
        applyRegister(next);
      });
    }
  }
  customElements.define('poc-register-toggle', PocRegisterToggle);
</script>

<style>
  @layer starlight.core {
    .site-title {
      align-items: center;
      gap: var(--sl-nav-gap);
      font-size: var(--sl-text-h4);
      font-weight: 600;
      color: var(--sl-color-text-accent);
      text-decoration: none;
      white-space: nowrap;
      min-width: 0;
      background: transparent;
      border: 0;
      padding: 0;
      cursor: pointer;
      font-family: var(--sl-font);
      line-height: normal;
    }

    .site-title:hover {
      opacity: 0.8;
    }

    span {
      overflow: visible;
    }

    img {
      height: calc(var(--sl-nav-height) - 2 * var(--sl-nav-pad-y));
      width: auto;
      max-width: 100%;
      object-fit: contain;
      object-position: 0 50%;
    }
  }

  .register-label {
    font-size: 0.65em;
    font-weight: 400;
    color: var(--poc-register-accent);
    margin-inline-start: 0.4em;
    vertical-align: super;
    letter-spacing: 0.02em;
    transition: color 0.3s ease;
    display: inline-flex;
    align-items: center;
    gap: 0.25em;
    line-height: 1;
  }

  .register-icon {
    flex-shrink: 0;
    width: 1.5cap;
    height: 1.5cap;
    align-self: center;
  }

  .label-beginner {
    display: none;
  }

  :global(:root[data-register='beginner']) .label-practitioner {
    display: none;
  }

  :global(:root[data-register='beginner']) .label-beginner {
    display: inline;
  }
</style>
