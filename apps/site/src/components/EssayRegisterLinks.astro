---
interface RegisterLink {
  readonly href: string;
  readonly label: string;
}

interface Props {
  readonly label?: string;
  readonly links: readonly RegisterLink[];
}

const { label = 'Continue in a different register', links } = Astro.props as Props;
---

<nav class="poc-register-links" aria-label={label}>
  <span class="poc-register-links__label">{label}</span>
  <ul class="poc-register-links__list">
    {links.map((link) => (
      <li>
        <a class="poc-register-links__link" href={link.href}>{link.label}</a>
      </li>
    ))}
  </ul>
</nav>

<style>
  .poc-register-links {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.45rem 0.7rem;
    margin-block: 1.7rem 0;
  }

  .poc-register-links__label {
    color: var(--poc-text-soft, var(--sl-color-gray-3));
    font-size: 0.84rem;
  }

  .poc-register-links__list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .poc-register-links__link {
    display: inline-flex;
    align-items: center;
    padding: 0.18rem 0.6rem;
    border: 1px solid color-mix(in srgb, var(--poc-box-border, var(--sl-color-gray-5)) 72%, transparent);
    border-radius: 999px;
    background: color-mix(in srgb, var(--poc-box-surface, var(--sl-color-gray-6)) 32%, transparent);
    color: var(--poc-text-soft, var(--sl-color-gray-3));
    font-size: 0.82rem;
    line-height: 1.35;
    text-decoration: none;
    transition:
      border-color 160ms ease,
      color 160ms ease,
      background-color 160ms ease;
    white-space: nowrap;
  }

  .poc-register-links__link:hover,
  .poc-register-links__link:focus-visible {
    border-color: color-mix(in srgb, var(--poc-reading-accent, currentColor) 28%, currentColor);
    background: color-mix(in srgb, var(--poc-box-surface, var(--sl-color-gray-6)) 42%, transparent);
    color: var(--poc-text-strong, var(--sl-color-text));
  }

  .poc-register-links__link:focus-visible {
    outline: 1px solid color-mix(in srgb, var(--poc-reading-accent, currentColor) 52%, currentColor);
    outline-offset: 0.14rem;
  }
</style>
