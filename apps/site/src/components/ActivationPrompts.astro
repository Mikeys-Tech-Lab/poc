---
import {
  ACTIVATION_BOUNDARY,
  ACTIVATION_COMPATIBILITY,
  ACTIVATION_DATA_BOUNDARY,
  ACTIVATION_INCOMPATIBILITY,
  GUIDED_ACTIVATION_PROMPT,
  MINIMAL_ACTIVATION_PROMPT,
  SEEDER_URL,
  SEEDER_VERSION_NOTE,
} from '../lib/activation-prompts';

interface Props {
  intro?: string;
  title?: string;
  guidedTitle?: string;
  minimalTitle?: string;
  summaryLabel?: string;
  variant?: 'full' | 'minimal-only';
}

const {
  intro,
  title = 'Paste-ready activation',
  guidedTitle = 'Guided activation prompt',
  minimalTitle = 'Minimal activation prompt',
  summaryLabel = 'Runtime entry',
  variant = 'full',
} = Astro.props as Props;

const minimalOnly = variant === 'minimal-only';
---

<poc-activation-prompts>
  <section class="reading-frame activation-prompts">
    <p class="reading-frame-label">{summaryLabel}</p>
    <p class="reading-frame-title">{title}</p>
    <div class="reading-frame-body activation-prompts-body">
      {intro && <p>{intro}</p>}
      <p class="activation-prompts-warning">
        <strong>Before you paste anything:</strong> {ACTIVATION_DATA_BOUNDARY}
      </p>
      {!minimalOnly && <p>{ACTIVATION_COMPATIBILITY}</p>}
      {!minimalOnly && <p class="activation-prompts-note">{ACTIVATION_INCOMPATIBILITY}</p>}
      {!minimalOnly && <p class="activation-prompts-boundary">{ACTIVATION_BOUNDARY}</p>}
      <p class="activation-prompts-seeder-note">{SEEDER_VERSION_NOTE}</p>

      {!minimalOnly && (
        <div class="activation-prompts-card activation-prompts-card-url">
          <div class="activation-prompts-card-header">
            <div>
              <p class="activation-prompts-card-label">Seeder URL</p>
              <p class="activation-prompts-card-title">Direct runtime entry</p>
            </div>
            <button
              type="button"
              class="activation-prompts-copy"
              data-copy-target="seeder-url"
              aria-label="Copy seeder URL"
            >
              <span data-copy-default>Copy URL</span>
              <span data-copy-success hidden>URL copied</span>
            </button>
          </div>
          <p class="activation-prompts-url-link">
            <a href={SEEDER_URL}>Open the public seeder URL</a>
          </p>
          <pre><code data-copy-source="seeder-url">{SEEDER_URL}</code></pre>
        </div>
      )}

      <div class="activation-prompts-card">
        <div class="activation-prompts-card-header">
          <div>
            <p class="activation-prompts-card-label">Prompt</p>
            <p class="activation-prompts-card-title">{minimalTitle}</p>
          </div>
          <button
            type="button"
            class="activation-prompts-copy"
            data-copy-target="minimal-prompt"
            aria-label="Copy minimal activation prompt"
          >
            <span data-copy-default>Copy minimal prompt</span>
            <span data-copy-success hidden>Minimal prompt copied</span>
          </button>
        </div>
        <pre><code data-copy-source="minimal-prompt">{MINIMAL_ACTIVATION_PROMPT}</code></pre>
      </div>

      {!minimalOnly && (
        <div class="activation-prompts-card">
          <div class="activation-prompts-card-header">
            <div>
              <p class="activation-prompts-card-label">Prompt</p>
              <p class="activation-prompts-card-title">{guidedTitle}</p>
            </div>
            <button
              type="button"
              class="activation-prompts-copy"
              data-copy-target="guided-prompt"
              aria-label="Copy guided activation prompt"
            >
              <span data-copy-default>Copy guided prompt</span>
              <span data-copy-success hidden>Guided prompt copied</span>
            </button>
          </div>
          <pre><code data-copy-source="guided-prompt">{GUIDED_ACTIVATION_PROMPT}</code></pre>
        </div>
      )}
    </div>
  </section>
</poc-activation-prompts>

<script>
  class PocActivationPrompts extends HTMLElement {
    connectedCallback() {
      if (this.dataset.bound === 'true') return;
      this.dataset.bound = 'true';

      this.querySelectorAll<HTMLButtonElement>('[data-copy-target]').forEach((button) => {
        button.addEventListener('click', async () => {
          const target = button.dataset.copyTarget;
          if (!target) return;

          const source = this.querySelector<HTMLElement>(`[data-copy-source="${target}"]`);
          const value = source?.textContent?.replace(/\s+$/, '');
          if (!value) return;

          try {
            await navigator.clipboard.writeText(value);
            const defaultLabel = button.querySelector<HTMLElement>('[data-copy-default]');
            const successLabel = button.querySelector<HTMLElement>('[data-copy-success]');
            if (!(defaultLabel && successLabel)) return;

            defaultLabel.hidden = true;
            successLabel.hidden = false;

            window.setTimeout(() => {
              defaultLabel.hidden = false;
              successLabel.hidden = true;
            }, 1800);
          } catch {
            // Clipboard API unavailable.
          }
        });
      });
    }
  }

  if (!customElements.get('poc-activation-prompts')) {
    customElements.define('poc-activation-prompts', PocActivationPrompts);
  }
</script>

<style>
  poc-activation-prompts {
    display: block;
    min-width: 0;
  }

  .activation-prompts {
    margin: 1.9rem 0;
    min-width: 0;
    background-color: var(--poc-box-activation-surface);
    border-color: var(--poc-box-activation-border);
    border-inline-start: 0.24rem solid var(--poc-box-activation-rail);
  }

  .activation-prompts-body {
    display: grid;
    gap: 1rem;
    min-width: 0;
  }

  .activation-prompts-note,
  .activation-prompts-boundary,
  .activation-prompts-seeder-note,
  .activation-prompts-warning {
    margin: 0;
  }

  .activation-prompts-warning {
    padding: 0.85rem 0.95rem;
    border: var(--poc-box-border-width) solid var(--poc-box-boundary-border);
    border-radius: 0.85rem;
    border-inline-start: 0.24rem solid var(--poc-box-boundary-rail);
    background-color: var(--poc-box-boundary-surface);
    box-shadow: var(--poc-box-shadow);
    color: var(--poc-text-strong);
  }

  :root:not([data-style='solid']) .activation-prompts-warning {
    backdrop-filter: blur(var(--poc-blur-sm));
  }

  .activation-prompts-warning strong {
    color: var(--poc-box-boundary-title);
  }

  .activation-prompts-note {
    color: var(--poc-text-soft);
  }

  .activation-prompts-boundary {
    color: var(--poc-text-strong);
  }

  .activation-prompts-seeder-note {
    color: var(--poc-text-soft);
  }

  .activation-prompts .reading-frame-label {
    color: color-mix(in srgb, var(--poc-box-activation-title) 72%, var(--poc-text-soft));
  }

  .activation-prompts .reading-frame-title,
  .activation-prompts-card-title {
    color: var(--poc-box-activation-title);
  }

  .activation-prompts-card {
    display: grid;
    gap: 0.75rem;
    padding: 1rem 1.05rem;
    border: var(--poc-box-border-width) solid var(--poc-box-border);
    border-radius: 0.9rem;
    background-color: var(--poc-box-surface);
    box-shadow: var(--poc-box-shadow);
    box-sizing: border-box;
    min-width: 0;
    max-width: 100%;
  }

  :root:not([data-style='solid']) .activation-prompts-card {
    backdrop-filter: blur(var(--poc-blur-sm));
  }

  .activation-prompts-card-header {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    align-items: flex-start;
    justify-content: space-between;
  }

  .activation-prompts-card-header > div {
    min-width: 0;
  }

  .activation-prompts-card-label,
  .activation-prompts-card-title {
    margin: 0;
  }

  .activation-prompts-card-label {
    color: var(--poc-text-soft);
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .activation-prompts-card-title {
    margin-top: 0.3rem;
    font-size: 1rem;
    font-weight: 600;
  }

  .activation-prompts-copy {
    display: inline-flex;
    align-items: center;
    gap: 0.35em;
    padding: 0.42em 0.78em;
    border: 1px solid var(--poc-box-control-border);
    border-radius: 0.6em;
    background: var(--poc-box-control-surface);
    box-shadow: var(--poc-box-control-shadow);
    color: var(--poc-text-strong, var(--sl-color-gray-2));
    font-size: var(--sl-text-xs);
    cursor: pointer;
    transition:
      color 0.15s ease,
      border-color 0.15s ease,
      background-color 0.15s ease,
      transform 0.15s ease;
    line-height: 1;
    max-width: 100%;
    white-space: normal;
    text-align: center;
    justify-content: center;
  }

  :root:not([data-style='solid']) .activation-prompts-copy {
    backdrop-filter: blur(var(--poc-blur-sm, 8px));
  }

  .activation-prompts-copy:hover {
    color: var(--sl-color-text-accent);
    border-color: var(--poc-box-control-hover-border);
    background: var(--poc-box-control-hover-surface);
    transform: translateY(-1px);
  }

  .activation-prompts-copy:focus-visible {
    outline: 2px solid var(--sl-color-text-accent);
    outline-offset: 2px;
  }

  .activation-prompts-url-link,
  .activation-prompts-card pre {
    margin: 0;
  }

  .activation-prompts-url-link a {
    overflow-wrap: anywhere;
    word-break: break-word;
  }

  .activation-prompts-card pre {
    padding: 0.95rem 1rem;
    border: 1px solid var(--poc-box-control-border);
    border-radius: 0.8rem;
    background-color: var(--poc-box-control-surface);
    box-shadow: inset 0 1px 0 rgb(255 255 255 / 0.02);
    white-space: pre-wrap;
    overflow-wrap: anywhere;
    box-sizing: border-box;
    max-width: 100%;
  }

  .activation-prompts-card code {
    display: block;
    font-size: 0.92rem;
    line-height: 1.6;
  }

  @media (max-width: 32rem) {
    .activation-prompts-card-header {
      flex-direction: column;
      align-items: stretch;
    }

    .activation-prompts-copy {
      width: 100%;
    }
  }
</style>
