---
/**
 * Lightweight copy-link control for article pages.
 *
 * Copies the canonical page URL to clipboard and briefly confirms
 * success inline. Renders as a single calm affordance near the
 * article metadata area.
 */
---

<poc-share-button>
	<button type="button" aria-label="Copy link to this page">
		<svg aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
			<path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8" />
			<polyline points="16 6 12 2 8 6" />
			<line x1="12" y1="2" x2="12" y2="15" />
		</svg>
		<span class="label">Copy link</span>
		<span class="copied" aria-live="polite" hidden>Link copied</span>
	</button>
</poc-share-button>

<script>
	import { buildShareUrl } from '../lib/share';

	class PocShareButton extends HTMLElement {
		connectedCallback() {
			const button = this.querySelector('button');
			if (!button) return;

			const label = this.querySelector('.label') as HTMLElement;
			const copied = this.querySelector('.copied') as HTMLElement;

			button.addEventListener('click', async () => {
				const url = buildShareUrl(window.location.href);
				try {
					await navigator.clipboard.writeText(url);
					label.hidden = true;
					copied.hidden = false;
					setTimeout(() => {
						label.hidden = false;
						copied.hidden = true;
					}, 2000);
				} catch {
					// Clipboard API unavailable
				}
			});
		}
	}

	customElements.define('poc-share-button', PocShareButton);
</script>

<style>
	poc-share-button {
		display: inline-flex;
		width: fit-content;
		max-width: 100%;
	}

	poc-share-button button {
		display: inline-flex;
		align-items: center;
		gap: 0.35em;
		padding: 0.42em 0.78em;
		border: 1px solid var(--poc-box-control-border);
		border-radius: 0.6em;
		background: var(--poc-box-control-surface);
		backdrop-filter: blur(var(--poc-blur-sm, 8px));
		box-shadow: var(--poc-box-control-shadow);
		color: var(--poc-text-strong, var(--sl-color-gray-2));
		font-size: var(--sl-text-xs);
		cursor: pointer;
		transition:
			color 0.15s ease,
			border-color 0.15s ease,
			background-color 0.15s ease,
			transform 0.15s ease;
		line-height: 1;
		white-space: nowrap;
	}

	poc-share-button button:hover {
		color: var(--sl-color-text-accent);
		border-color: var(--poc-box-control-hover-border);
		background: var(--poc-box-control-hover-surface);
		transform: translateY(-1px);
	}

	poc-share-button svg {
		flex-shrink: 0;
		opacity: 0.92;
	}

	poc-share-button .copied {
		color: var(--sl-color-text-accent);
	}
</style>
