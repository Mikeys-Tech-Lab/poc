---
import type { EssayAnchor } from '../content/structural-essays/types';

interface Props {
  anchor: EssayAnchor;
}

const { anchor } = Astro.props as Props;
---

<article class="poc-anchor-card">
  <p class="poc-anchor-entry">{anchor.entryLabel}</p>
  <h3>{anchor.title}</h3>
  <p class="poc-anchor-signal">{anchor.signal}</p>
  <p class="poc-anchor-question">{anchor.question}</p>
  <a href={anchor.href}>Start here</a>
</article>

<style>
  .poc-anchor-card {
    display: grid;
    gap: 0.58rem;
    padding: 0.95rem 1rem;
    border: 1px solid color-mix(in srgb, var(--poc-box-card-border) 72%, var(--poc-box-border));
    border-inline-start: 0.16rem solid color-mix(in srgb, var(--poc-box-card-rail) 62%, var(--poc-border));
    border-radius: 0.8rem;
    background: var(--poc-box-row-surface);
    backdrop-filter: blur(var(--poc-blur-sm));
    box-shadow: none;
  }

  .poc-anchor-card > * {
    margin: 0;
  }

  .poc-anchor-entry {
    color: var(--poc-text-soft, var(--sl-color-gray-3));
    font-size: 0.78rem;
    font-weight: 650;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .poc-anchor-card h3 {
    color: var(--poc-box-card-title);
    font-size: 1rem;
  }

  .poc-anchor-signal {
    color: var(--poc-text-soft, var(--sl-color-gray-3));
    font-size: 0.92rem;
    line-height: 1.5;
  }

  .poc-anchor-question {
    color: var(--poc-text-strong, var(--sl-color-gray-2));
    font-weight: 600;
  }

  .poc-anchor-card a {
    width: fit-content;
  }
</style>
