---
import type { EssayAnchor } from '../lib/structural-essays/ai-is-not-magic-it-is-a-mirror-with-a-motor';

interface Props {
  anchor: EssayAnchor;
}

const { anchor } = Astro.props as Props;
---

<article class="poc-anchor-card">
  <p class="poc-anchor-entry">{anchor.entryLabel}</p>
  <h3>{anchor.title}</h3>
  <p class="poc-anchor-signal">{anchor.signal}</p>
  <p class="poc-anchor-question">{anchor.question}</p>
  <a href={anchor.href}>Start here</a>
</article>

<style>
  .poc-anchor-card {
    display: grid;
    gap: 0.62rem;
    padding: 1rem 1.05rem;
    border: var(--poc-box-border-width) solid var(--poc-box-card-border);
    border-inline-start: 0.24rem solid var(--poc-box-card-rail);
    border-radius: 0.9rem;
    background: var(--poc-box-surface);
    backdrop-filter: blur(var(--poc-blur-sm));
    box-shadow: var(--poc-box-shadow);
  }

  .poc-anchor-card > * {
    margin: 0;
  }

  .poc-anchor-entry {
    color: var(--poc-text-strong, var(--sl-color-gray-2));
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .poc-anchor-card h3 {
    color: var(--poc-box-card-title);
    font-size: 1.05rem;
  }

  .poc-anchor-signal {
    color: var(--poc-text-soft, var(--sl-color-gray-3));
    font-size: 0.92rem;
    line-height: 1.5;
  }

  .poc-anchor-question {
    color: var(--poc-text-strong, var(--sl-color-gray-2));
    font-weight: 650;
  }

  .poc-anchor-card a {
    width: fit-content;
  }
</style>
