---
import { getLocaleFromPath } from '../lib/locale';
import { getA11yLabels } from '../lib/i18n';

const locale = getLocaleFromPath(Astro.url?.pathname ?? '/');
const t = getA11yLabels(locale);
---

<poc-a11y-panel>
	<button type="button" class="a11y-trigger" aria-label={t.openPanel} title={t.openPanel}>
		<svg aria-hidden="true" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
			<circle cx="12" cy="4.5" r="2.5" />
			<path d="m4.5 9.5 3 1 4.5 1 4.5-1 3-1" />
			<path d="M8 14.5 7 22" />
			<path d="m16 14.5 1 7.5" />
			<path d="M12 12.5v4" />
		</svg>
	</button>

	<dialog class="a11y-dialog">
		<div class="a11y-dialog-inner">
			<div class="a11y-header">
				<h2>{t.panelTitle}</h2>
				<button type="button" class="a11y-close" aria-label={t.close}>
					<svg aria-hidden="true" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
						<line x1="18" y1="6" x2="6" y2="18" />
						<line x1="6" y1="6" x2="18" y2="18" />
					</svg>
				</button>
			</div>

			<div class="a11y-controls">
				<label class="a11y-toggle">
					<span>{t.contrast}</span>
					<input type="checkbox" data-a11y-control="contrast" />
				</label>

				<label class="a11y-select">
					<span>{t.textSize}</span>
					<select data-a11y-control="text">
						<option value="100">100%</option>
						<option value="125">125%</option>
						<option value="150">150%</option>
						<option value="175">175%</option>
						<option value="200">200%</option>
					</select>
				</label>

				<label class="a11y-toggle">
					<span>{t.reduceMotion}</span>
					<input type="checkbox" data-a11y-control="motion" />
				</label>

				<label class="a11y-toggle">
					<span>{t.solidShortcut}</span>
					<input type="checkbox" data-a11y-control="solid" />
				</label>

				<label class="a11y-toggle">
					<span>{t.underlineLinks}</span>
					<input type="checkbox" data-a11y-control="links" />
				</label>

				<label class="a11y-toggle">
					<span>{t.altFont}</span>
					<input type="checkbox" data-a11y-control="font" />
				</label>
			</div>

			<button type="button" class="a11y-reset">{t.reset}</button>
		</div>
	</dialog>
</poc-a11y-panel>

<script>
	import {
		loadPreferences,
		setPreferences,
		resetPreferences,
		DEFAULTS,
		type A11yPreferences,
	} from '../lib/a11y-preferences';

	const themeStorageKey = 'starlight-theme';
	const atmosphericThemeStorageKey = 'poc-atmospheric-theme';

	type Theme = 'auto' | 'dark' | 'light' | 'dark-solid' | 'light-solid';

	const parseTheme = (theme: unknown): Theme =>
		theme === 'auto' ||
		theme === 'dark' ||
		theme === 'light' ||
		theme === 'dark-solid' ||
		theme === 'light-solid'
			? theme
			: 'auto';

	const loadTheme = (): Theme =>
		parseTheme(typeof localStorage !== 'undefined' && localStorage.getItem(themeStorageKey));

	const toAtmosphericTheme = (theme: Theme): 'auto' | 'dark' | 'light' =>
		theme === 'dark-solid'
			? 'dark'
			: theme === 'light-solid'
				? 'light'
				: theme;

	function isSolidTheme(): boolean {
		return loadTheme().includes('solid');
	}

	function setSolidTheme(solid: boolean): void {
		const currentTheme = loadTheme();
		const isSolid = currentTheme.includes('solid');

		if (solid && !isSolid) {
			const colorScheme = document.documentElement.dataset.theme === 'light' ? 'light' : 'dark';
			const newTheme = `${colorScheme}-solid` as Theme;
			localStorage.setItem(atmosphericThemeStorageKey, currentTheme);
			localStorage.setItem(themeStorageKey, newTheme);
			document.documentElement.dataset.style = 'solid';
			StarlightThemeProvider.updatePickers(newTheme);
		} else if (!solid && isSolid) {
			const storedAtmosphericTheme =
				typeof localStorage !== 'undefined' &&
				localStorage.getItem(atmosphericThemeStorageKey);
			const fallbackAtmosphericTheme = currentTheme.startsWith('light') ? 'light' : 'dark';
			const atmosphericTheme = toAtmosphericTheme(
				parseTheme(storedAtmosphericTheme || fallbackAtmosphericTheme),
			);
			localStorage.setItem(themeStorageKey, atmosphericTheme === 'auto' ? '' : atmosphericTheme);
			delete document.documentElement.dataset.style;
			StarlightThemeProvider.updatePickers(atmosphericTheme);
		}
	}

	class PocA11yPanel extends HTMLElement {
		dialog: HTMLDialogElement;
		prefs: A11yPreferences;

		constructor() {
			super();
			this.dialog = this.querySelector('dialog')!;
			this.prefs = loadPreferences();

			this.querySelector('.a11y-trigger')?.addEventListener('click', () => {
				this.syncControlsFromPrefs();
				this.dialog.showModal();
			});

			this.querySelector('.a11y-close')?.addEventListener('click', () => {
				this.dialog.close();
			});

			this.querySelector('.a11y-reset')?.addEventListener('click', () => {
				resetPreferences();
				setSolidTheme(false);
				this.prefs = { ...DEFAULTS };
				this.syncControlsFromPrefs();
			});

			this.dialog.addEventListener('click', (e) => {
				if (e.target === this.dialog) this.dialog.close();
			});

			for (const input of this.querySelectorAll<HTMLInputElement>('[data-a11y-control]')) {
				const key = input.dataset.a11yControl!;
				if (key === 'solid') {
					input.addEventListener('change', () => setSolidTheme(input.checked));
				} else if (input.type === 'checkbox') {
					input.addEventListener('change', () => {
						this.prefs = {
							...this.prefs,
							[key]: input.checked ? this.activeValue(key) : 'default',
						};
						setPreferences(this.prefs);
					});
				}
			}

			const textSelect = this.querySelector<HTMLSelectElement>('[data-a11y-control="text"]');
			textSelect?.addEventListener('change', () => {
				this.prefs = { ...this.prefs, text: textSelect.value as A11yPreferences['text'] };
				setPreferences(this.prefs);
			});

			window.addEventListener('poc:a11y-change', (e) => {
				this.prefs = (e as CustomEvent).detail;
			});
		}

		activeValue(key: string): string {
			const map: Record<string, string> = {
				contrast: 'more',
				motion: 'reduce',
				links: 'underline',
				font: 'alt',
			};
			return map[key] ?? 'default';
		}

		syncControlsFromPrefs(): void {
			for (const input of this.querySelectorAll<HTMLInputElement>('[data-a11y-control]')) {
				const key = input.dataset.a11yControl!;
				if (key === 'solid') {
					input.checked = isSolidTheme();
				} else if (key === 'text') {
					continue;
				} else if (input.type === 'checkbox') {
					input.checked = (this.prefs as unknown as Record<string, string>)[key] !== 'default';
				}
			}
			const textSelect = this.querySelector<HTMLSelectElement>('[data-a11y-control="text"]');
			if (textSelect) textSelect.value = this.prefs.text;
		}
	}

	customElements.define('poc-a11y-panel', PocA11yPanel);
</script>

<style>
	.a11y-trigger {
		display: flex;
		align-items: center;
		justify-content: center;
		background: transparent;
		border: 0;
		padding: 0.5em;
		margin: -0.5em;
		color: var(--sl-color-text-accent);
		cursor: pointer;
	}
	.a11y-trigger:hover {
		opacity: 0.66;
	}

	.a11y-dialog {
		position: fixed;
		inset: 0 0 0 auto;
		width: min(22rem, 85vw);
		max-width: none;
		max-height: none;
		height: 100dvh;
		margin: 0;
		padding: 0;
		border: 0;
		border-inline-start: 1px solid var(--poc-border);
		background-color: var(--poc-surface-panel);
		backdrop-filter: blur(var(--poc-blur-xl));
		color: var(--sl-color-text);
		overflow-y: auto;
	}

	.a11y-dialog::backdrop {
		background-color: var(--poc-backdrop);
		backdrop-filter: blur(4px);
	}

	.a11y-dialog-inner {
		display: flex;
		flex-direction: column;
		gap: 1rem;
		padding: 1.25rem;
	}

	.a11y-header {
		display: flex;
		align-items: center;
		justify-content: space-between;
	}

	.a11y-header h2 {
		margin: 0;
		font-size: var(--sl-text-lg);
		font-weight: 600;
		color: var(--sl-color-text-accent);
	}

	.a11y-close {
		display: flex;
		align-items: center;
		justify-content: center;
		background: transparent;
		border: 0;
		padding: 0.4em;
		color: var(--sl-color-text);
		cursor: pointer;
		border-radius: 0.25rem;
	}
	.a11y-close:hover {
		background-color: var(--poc-surface);
	}

	.a11y-controls {
		display: flex;
		flex-direction: column;
		gap: 0.875rem;
	}

	.a11y-toggle,
	.a11y-select {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.75rem;
		padding: 0.625rem 0.75rem;
		background-color: var(--poc-surface-faint);
		border: 1px solid var(--poc-border-subtle);
		border-radius: 0.5rem;
		cursor: pointer;
		font-size: var(--sl-text-sm);
		color: var(--sl-color-text);
	}
	.a11y-toggle:hover,
	.a11y-select:hover {
		border-color: var(--poc-border-hover);
	}

	.a11y-toggle span,
	.a11y-select span {
		flex: 1;
		min-width: 0;
	}

	.a11y-toggle input[type="checkbox"] {
		flex-shrink: 0;
		width: 2.5rem;
		height: 1.375rem;
		appearance: none;
		background-color: var(--poc-surface-raised);
		border: 1px solid var(--poc-border);
		border-radius: 1rem;
		position: relative;
		cursor: pointer;
		transition: background-color 0.15s ease;
	}
	.a11y-toggle input[type="checkbox"]::before {
		content: '';
		position: absolute;
		top: 2px;
		left: 2px;
		width: 1rem;
		height: 1rem;
		border-radius: 50%;
		background-color: var(--sl-color-text);
		transition: transform 0.15s ease;
	}
	.a11y-toggle input[type="checkbox"]:checked {
		background-color: var(--sl-color-accent);
		border-color: var(--sl-color-accent);
	}
	.a11y-toggle input[type="checkbox"]:checked::before {
		transform: translateX(calc(2.5rem - 1rem - 6px));
		background-color: var(--sl-color-accent-text);
	}

	.a11y-select select {
		padding: 0.25rem 0.5rem;
		border: 1px solid var(--poc-border);
		border-radius: 0.375rem;
		background-color: var(--poc-surface);
		color: var(--sl-color-text);
		font-size: var(--sl-text-sm);
		cursor: pointer;
	}

	.a11y-reset {
		margin-top: 0.5rem;
		padding: 0.5rem 1rem;
		background-color: transparent;
		border: 1px solid var(--poc-border);
		border-radius: 0.5rem;
		color: var(--sl-color-text);
		font-size: var(--sl-text-sm);
		cursor: pointer;
		text-align: center;
	}
	.a11y-reset:hover {
		background-color: var(--poc-surface-faint);
		border-color: var(--poc-border-hover);
	}

	/* Focus visibility */
	.a11y-trigger:focus-visible,
	.a11y-close:focus-visible,
	.a11y-reset:focus-visible,
	.a11y-toggle input:focus-visible,
	.a11y-select select:focus-visible {
		outline: 2px solid var(--sl-color-accent);
		outline-offset: 2px;
	}
</style>
