---
import type { DirectSourceEntry } from '../content/structural-essays/types';

interface Props {
  readonly sourceId: string;
  readonly sources?: readonly DirectSourceEntry[];
  readonly label?: string;
}

const { sourceId, sources = [], label } = Astro.props as Props;
const source = sources.find((entry) => entry.id === sourceId);
const href = `#source-${sourceId}`;
const accessibleLabel = source ? `Open source: ${source.title}` : 'Open source details';
const renderedLabel = label ?? source?.label ?? 'Source';
---

<sup class="poc-source-reference">
  <a class="poc-source-reference__link" href={href} aria-label={accessibleLabel}>
    <slot>{renderedLabel}</slot>
  </a>
</sup>

<style>
  .poc-source-reference {
    margin-inline-start: 0.16em;
    font-size: 0.68em;
    line-height: 0;
    vertical-align: super;
  }

  .poc-source-reference__link {
    display: inline;
    color: var(--poc-text-strong, var(--sl-color-text-accent));
    font-weight: 600;
    letter-spacing: 0.01em;
    opacity: 0.68;
    text-decoration: none;
    text-underline-offset: 0.12em;
    text-decoration-thickness: 0.08em;
    white-space: nowrap;
  }

  .poc-source-reference__link:hover,
  .poc-source-reference__link:focus-visible {
    opacity: 1;
    text-decoration: underline;
    text-decoration-color: currentColor;
  }

  .poc-source-reference__link:focus-visible {
    outline: 1px solid color-mix(in srgb, var(--poc-reading-accent) 55%, currentColor);
    outline-offset: 0.14em;
    border-radius: 0.18em;
  }
</style>
