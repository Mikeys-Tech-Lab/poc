---
import { Icon } from '@astrojs/starlight/components';
---

{/*
  Inlined to prevent FOUC. Sets data-theme, data-style, and data-register
  before first paint. This script MUST be is:inline because Vite-processed
  module scripts are deferred and would cause a flash.

  The register storage key ('poc-register') and parsing logic are intentionally
  duplicated from src/lib/register.ts. Inline scripts cannot use ES imports.
  If the key or default changes, update both locations.
*/}
<script is:inline>
	window.StarlightThemeProvider = (() => {
		const stored =
			typeof localStorage !== 'undefined' && localStorage.getItem('starlight-theme');
		const theme = stored || 'auto';
		const isSolid = theme.includes('solid');
		const colorScheme = theme.startsWith('light')
			? 'light'
			: theme === 'auto'
				? (window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark')
				: 'dark';

		document.documentElement.dataset.theme = colorScheme;
		if (isSolid) {
			document.documentElement.dataset.style = 'solid';
		} else {
			delete document.documentElement.dataset.style;
		}

		const urlRegister = new URLSearchParams(window.location.search).get('register');
		const storedRegister =
			typeof localStorage !== 'undefined' && localStorage.getItem('poc-register');
		const register = urlRegister || storedRegister;
		document.documentElement.dataset.register = register === 'beginner' ? 'beginner' : 'practitioner';
		if (urlRegister && typeof localStorage !== 'undefined') {
			localStorage.setItem('poc-register', register === 'beginner' ? 'beginner' : 'practitioner');
		}

		/* ── Accessibility preferences (duplicated from a11y-preferences.ts) ── */
		const a11yDefaults = { contrast: 'default', text: '100', motion: 'default', links: 'default', font: 'default' };
		let a11y = a11yDefaults;
		try {
			const raw = typeof localStorage !== 'undefined' && localStorage.getItem('poc-a11y');
			if (raw) {
				const parsed = JSON.parse(raw);
				a11y = {
					contrast: parsed.contrast === 'more' ? 'more' : 'default',
					text: parsed.text === '112' ? '112' : parsed.text === '125' ? '125' : '100',
					motion: parsed.motion === 'reduce' ? 'reduce' : 'default',
					links: parsed.links === 'underline' ? 'underline' : 'default',
					font: parsed.font === 'alt' ? 'alt' : 'default',
				};
			}
		} catch (_) { /* ignore corrupt storage */ }
		const d = document.documentElement.dataset;
		d.a11yContrast = a11y.contrast;
		d.a11yText = a11y.text;
		d.a11yMotion = a11y.motion;
		d.a11yLinks = a11y.links;
		d.a11yFont = a11y.font;

		return {
			updatePickers(theme = stored || 'auto') {
				document.querySelectorAll('starlight-theme-select').forEach((picker) => {
					const select = picker.querySelector('select');
					if (select) select.value = theme;
					/** @type {HTMLTemplateElement | null} */
					const tmpl = document.querySelector('#theme-icons');
					const iconClass = theme.replace('-solid', '');
					const newIcon = tmpl && tmpl.content.querySelector('.' + iconClass);
					if (newIcon) {
						const oldIcon = picker.querySelector('svg.label-icon');
						if (oldIcon) {
							oldIcon.replaceChildren(...newIcon.cloneNode(true).childNodes);
						}
					}
				});
			},
		};
	})();
</script>

<template id="theme-icons">
	<Icon name="sun" class="light" />
	<Icon name="moon" class="dark" />
	<Icon name="laptop" class="auto" />
</template>
