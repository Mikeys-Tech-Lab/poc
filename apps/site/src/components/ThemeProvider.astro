---
import { Icon } from '@astrojs/starlight/components';
import { getRegisterAvailabilityForPath } from '../lib/route-map.js';

const registerAvailability = getRegisterAvailabilityForPath(Astro.url?.pathname ?? '/');
---

{/*
  Inlined to prevent FOUC. Sets data-theme, data-style, and data-register
  before first paint. This script MUST be is:inline because Vite-processed
  module scripts are deferred and would cause a flash.

  The register storage key ('poc-register') and parsing logic are intentionally
  duplicated from src/lib/register.ts. Inline scripts cannot use ES imports.
  If the key or default changes, update both locations.
*/}
<script is:inline define:vars={{ registerAvailability }}>
	window.StarlightThemeProvider = (() => {
		const stored =
			typeof localStorage !== 'undefined' && localStorage.getItem('starlight-theme');
		const theme =
			stored === 'light' ||
			stored === 'dark' ||
			stored === 'dark-solid' ||
			stored === 'light-solid'
				? stored
				: 'dark';
		const isSolid = theme.includes('solid');
		const colorScheme = theme.startsWith('light')
			? 'light'
			: 'dark';

		document.documentElement.dataset.theme = colorScheme;
		if (isSolid) {
			document.documentElement.dataset.style = 'solid';
		} else {
			delete document.documentElement.dataset.style;
		}
		if (typeof localStorage !== 'undefined' && stored !== theme) {
			localStorage.setItem('starlight-theme', theme);
		}

		const readingRegisters = ['everyday', 'orientation', 'practitioner'];
		const isReadingRegister = (value) => readingRegisters.includes(value);
		const availableRegisters = Array.isArray(registerAvailability.available)
			? registerAvailability.available.filter(isReadingRegister)
			: ['practitioner', 'orientation'];
		const absentRegisters =
			registerAvailability.absent && typeof registerAvailability.absent === 'object'
				? registerAvailability.absent
				: { everyday: 'Everyday is not available for this page yet.' };
		const defaultRegister =
			isReadingRegister(registerAvailability.defaultRegister) &&
			availableRegisters.includes(registerAvailability.defaultRegister)
				? registerAvailability.defaultRegister
				: availableRegisters.includes('practitioner')
					? 'practitioner'
					: availableRegisters[0] || 'practitioner';
		const resolveRegister = (value) => {
			const requested = isReadingRegister(value) ? value : null;
			if (requested && availableRegisters.includes(requested)) {
				return { register: requested, requested, reason: null, message: null };
			}
			return {
				register: defaultRegister,
				requested,
				reason: requested ? 'unavailable' : 'unknown',
				message: requested
					? absentRegisters[requested] || `${requested} is not available for this page.`
					: 'Unknown register requested. Showing the default register.',
			};
		};

		const urlRegister = new URLSearchParams(window.location.search).get('register');
		const storedRegister =
			typeof localStorage !== 'undefined' && localStorage.getItem('poc-register');
		const resolution = resolveRegister(urlRegister || storedRegister);
		document.documentElement.dataset.registerDefault = defaultRegister;
		document.documentElement.dataset.registerAvailable = availableRegisters.join(',');
		document.documentElement.dataset.registerAbsent = JSON.stringify(absentRegisters);
		document.documentElement.dataset.register = resolution.register;
		if (resolution.reason && resolution.message) {
			document.documentElement.dataset.registerFallbackReason = resolution.reason;
			document.documentElement.dataset.registerFallbackMessage = resolution.message;
			if (resolution.requested) {
				document.documentElement.dataset.registerRequested = resolution.requested;
			}
		}
		if (urlRegister && typeof localStorage !== 'undefined') {
			localStorage.setItem('poc-register', resolution.register);
		}

		/* ── Accessibility preferences (duplicated from a11y-preferences.ts) ── */
		const a11yDefaults = { contrast: 'default', text: '100', motion: 'default', links: 'default', font: 'default' };
		let a11y = a11yDefaults;
		try {
			const raw = typeof localStorage !== 'undefined' && localStorage.getItem('poc-a11y');
			if (raw) {
				const parsed = JSON.parse(raw);
				a11y = {
					contrast: parsed.contrast === 'more' ? 'more' : 'default',
					text: parsed.text === '125' ? '125' : parsed.text === '150' ? '150' : parsed.text === '175' ? '175' : parsed.text === '200' ? '200' : '100',
					motion: parsed.motion === 'reduce' ? 'reduce' : 'default',
					links: parsed.links === 'underline' ? 'underline' : 'default',
					font: parsed.font === 'alt' ? 'alt' : 'default',
				};
			}
		} catch (_) { /* ignore corrupt storage */ }
		const d = document.documentElement.dataset;
		d.a11yContrast = a11y.contrast;
		d.a11yText = a11y.text;
		d.a11yMotion = a11y.motion;
		d.a11yLinks = a11y.links;
		d.a11yFont = a11y.font;

		document.addEventListener('DOMContentLoaded', () => {
			document.querySelectorAll('.expressive-code > figure > pre').forEach((element) => {
				if (element instanceof HTMLElement && !element.hasAttribute('tabindex')) {
					element.tabIndex = 0;
				}
			});
		});

		return {
			updatePickers(theme = theme) {
				document.querySelectorAll('starlight-theme-select').forEach((picker) => {
					const select = picker.querySelector('select');
					if (select) select.value = theme;
					/** @type {HTMLTemplateElement | null} */
					const tmpl = document.querySelector('#theme-icons');
					const iconClass = theme.replace('-solid', '');
					const newIcon = tmpl && tmpl.content.querySelector('.' + iconClass);
					if (newIcon) {
						const oldIcon = picker.querySelector('svg.label-icon');
						if (oldIcon) {
							oldIcon.replaceChildren(...newIcon.cloneNode(true).childNodes);
						}
					}
				});
			},
		};
	})();
</script>

<template id="theme-icons">
	<Icon name="sun" class="light" />
	<Icon name="moon" class="dark" />
</template>
