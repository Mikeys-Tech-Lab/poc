---
import { render } from 'astro:content';
import HandoutStarlightPage from '../../../../components/HandoutStarlightPage.astro';
import {
  buildThinkfirstSidebar,
  getHandoutSlug,
  getThinkfirstHandouts,
  getThinkfirstHandoutBySlug,
} from '../../../../lib/handouts';

export const getStaticPaths = async () => {
  const handouts = await getThinkfirstHandouts();

  return handouts.map((entry) => ({
    params: { slug: getHandoutSlug(entry) },
    props: { entryId: entry.id },
  }));
};

const { slug } = Astro.params;

if (!slug) {
  return new Response(null, { status: 404, statusText: 'Not Found' });
}

const entry = await getThinkfirstHandoutBySlug(slug);

if (!entry) {
  return new Response(null, { status: 404, statusText: 'Not Found' });
}

const { Content, headings } = await render(entry);
const sidebar = await buildThinkfirstSidebar();
---

<HandoutStarlightPage
  frontmatter={{
    title: entry.data.title,
    description: entry.data.description,
    pagefind: false,
  }}
  sidebar={sidebar}
  headings={headings}
>
  <Content />
</HandoutStarlightPage>
