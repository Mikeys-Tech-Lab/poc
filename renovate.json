{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    ":dependencyDashboard",
    ":semanticCommits",
    ":semanticCommitTypeAll(chore)",
    ":semanticCommitScope(deps)"
  ],
  "timezone": "UTC",
  "schedule": ["before 5am on monday"],
  "prCreation": "not-pending",
  "rangeStrategy": "bump",
  "rebaseWhen": "behind-base-branch",
  "prConcurrentLimit": 5,
  "branchConcurrentLimit": 5,
  "labels": ["dependencies"],
  "minimumReleaseAge": "3 days",
  "internalChecksFilter": "strict",
  "vulnerabilityAlerts": {
    "labels": ["dependencies", "security"],
    "automerge": true,
    "automergeType": "pr",
    "minimumReleaseAge": null,
    "vulnerabilityFixStrategy": "lowest"
  },
  "major": {
    "dependencyDashboardApproval": true,
    "automerge": false
  },
  "packageRules": [
    {
      "description": "Automerge lock file maintenance after CI.",
      "matchUpdateTypes": ["lockFileMaintenance"],
      "groupName": "lock file maintenance",
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "description": "Automerge non-major GitHub Actions updates after CI.",
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["minor", "patch", "pin", "digest"],
      "groupName": "github actions non-major",
      "labels": ["dependencies", "ci"],
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "description": "Hold GitHub Actions majors for dashboard-driven review.",
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["major"],
      "labels": ["dependencies", "ci"],
      "dependencyDashboardApproval": true,
      "automerge": false
    },
    {
      "description": "Batch all npm minor and patch updates into one PR, automerge after CI.",
      "matchManagers": ["npm"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "npm non-major",
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "description": "Hold TypeScript 7 until @astrojs/check supports it. astro check uses @astrojs/language-server, which currently peers typescript ^5 || ^6 only. Remove this rule once @astrojs/check adds TS 7 support.",
      "matchPackageNames": ["typescript"],
      "allowedVersions": "<7"
    }
  ]
}
